{
  "theme": "light",
  "archetype": "Swiss & High-Contrast",
  "language": "pt-BR",
  "design_philosophy": "Color is Function Only. 95% of the UI should be monochrome. Color exists only to guide action. Sharp, dense, and scanable dashboard for high-volume callcenter operations.",
  "colors": {
    "background": {
      "main": "#F8F9FA",
      "surface": "#FFFFFF",
      "sidebar": "#09090B",
      "glass": "rgba(255, 255, 255, 0.8)"
    },
    "text": {
      "primary": "#09090B",
      "secondary": "#52525B",
      "tertiary": "#A1A1AA",
      "inverse": "#FAFAFA"
    },
    "brand": {
      "primary": "#000000",
      "primary_hover": "#27272A",
      "accent": "#2563EB"
    },
    "status": {
      "online": "#16A34A",
      "offline": "#DC2626",
      "paused": "#D97706",
      "ringing": "#2563EB",
      "incall": "#9333EA",
      "missed": "#EF4444"
    },
    "border": {
      "default": "#E4E4E7",
      "focus": "#18181B"
    }
  },
  "typography": {
    "headings": {
      "family": "Cabinet Grotesk, sans-serif",
      "weights": ["500", "700", "800"],
      "tracking": "tracking-tight"
    },
    "body": {
      "family": "Inter, sans-serif",
      "weights": ["400", "500"]
    },
    "mono": {
      "family": "JetBrains Mono, monospace",
      "weights": ["400"],
      "usage": "Timers, caller IDs, precise data"
    },
    "sizes": {
      "h1": "text-3xl sm:text-4xl",
      "h2": "text-2xl sm:text-3xl",
      "h3": "text-xl",
      "h4": "text-lg",
      "body": "text-sm",
      "caption": "text-xs uppercase tracking-widest",
      "kpi_value": "text-4xl sm:text-5xl tracking-tighter font-medium"
    }
  },
  "spacing_and_layout": {
    "dashboard_grid": "grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-4",
    "kpi_cards": "col-span-1",
    "main_chart": "col-span-2 lg:col-span-3",
    "feed_list": "col-span-1 row-span-2",
    "card_padding": "p-5",
    "border_radius": "rounded-none md:rounded-sm",
    "shadows": {
      "card": "shadow-sm",
      "hover": "shadow-md transition-shadow duration-200"
    }
  },
  "components": {
    "sidebar": {
      "style": "solid dark background (#09090B), light text, strict vertical hierarchy",
      "active_state": "bg-white/10 text-white border-l-2 border-white",
      "items": [
        { "label": "Dashboard", "icon": "SquaresFour", "route": "/" },
        { "label": "Chamadas em Tempo Real", "icon": "PhoneCall", "route": "/realtime" },
        { "label": "Gravações", "icon": "CassetteTape", "route": "/recordings" },
        { "label": "Relatórios de Agentes", "icon": "ChartBar", "route": "/reports" },
        { "label": "Filas (Queues)", "icon": "UsersThree", "route": "/queues" },
        { "label": "Gerenciamento", "icon": "Gear", "route": "/management" }
      ]
    },
    "kpi_cards": {
      "style": "Flat background, 1px solid border-border, no heavy drop shadow. Numeric values in JetBrains Mono.",
      "layout": "Flex column, label on top (text-xs uppercase text-secondary), big value below, trend indicator on right."
    },
    "tables": {
      "style": "Dense padding (py-2 px-3), 1px bottom border per row. Hover state applies bg-zinc-50.",
      "headers": "text-xs font-medium text-secondary uppercase bg-zinc-50 border-y border-zinc-200",
      "actions": "Icons aligned to the right (Play, Download, View Profile)"
    },
    "audio_player": {
      "style": "Sticky bottom bar or inline row expansion. Minimalist waveform visualization.",
      "controls": "Play/Pause, Timeline slider, Speed multiplier (1x, 1.5x, 2x), Download button."
    },
    "badges": {
      "style": "Subtle background, solid text, no borders. px-2 py-0.5 rounded-full text-xs font-medium",
      "online": "bg-green-100 text-green-700",
      "offline": "bg-red-100 text-red-700",
      "incall": "bg-purple-100 text-purple-700"
    }
  },
  "motion": {
    "hover": "transition-colors duration-150 ease-in-out",
    "lists": "Staggered fade-up for table rows on initial load",
    "realtime": "Pulse animation (ring) on 'ringing' status dots"
  },
